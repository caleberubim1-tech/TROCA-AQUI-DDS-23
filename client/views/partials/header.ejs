<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TROCA APP</title>

    <!-- IMPORTAÇÃO DO FONT AWESOME -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <!-- IMPORTAÇÃO DO BOOTSTRAP -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr"
      crossorigin="anonymous"
    />

    <!-- IMPORTAÇÃO DO CSS -->
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="header-sistema">
      <!-- Logo do site, na esquerda -->
      <a href="#">
        <img src="/img/logo2horizontalss.png" alt="logo" width="240" height="70" />
      </a>

      <!-- Opções de menu, na direita -->
      <nav class="nav-menu">

        <!-- SE TIVER LOGADO -->
        <% if (typeof usuario !== 'undefined' && usuario) { %>

          <!-- MOSTRA NOME DO USUÁRIO -->
            <span style="color: var(--cor-destaque); font-weight: bold; margin-right: 15px;">
                <i class="fa-solid fa-user"></i> Olá, <%= usuario.nome %>
            </span>

          <!-- MEIO -->

          <!-- Se for adm -->
          <% if (usuario.perfil === 'administrador') { %>
            <div class="dropdown d-inline-block">
                <!-- Botão de ativar -->
                <button class="dropdown-btn dropdown-toggle btn" type="button" data-bs-toggle="dropdown" aria-expanded="false"
                style="background: transparent; border: none;">
                    <i class="fa-solid fa-user-shield"></i> Gerenciamento do Admin
                    </button>
                <!-- Sub-opções de menu -->
                <ul class="dropdown-menu">
                  <li> <a href="/usuarios" class="dropdown-item">
                    <i class="fa-solid fa-users"></i>
                    Visualizar usuários</a> 
                  </li>
                  <li> <a href="/usuarios/cadastro" class="dropdown-item">
                    <i class="fa-solid fa-user-plus"></i>
                    Cadastrar novo </a> 
                  </li>
                </ul>
            </div>
          <% } %>

          <!-- Se for ofertante -->
          <% if (usuario.perfil === 'ofertante') { %>
            <div class="dropdown d-inline-block">
                <!-- Botão de ativar -->
                <button class="dropdown-btn dropdown-toggle btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="background: transparent; border: none;">
                    <i class="fa-solid fa-box"></i> Meus Produtos </button>
                <!-- Sub-opções de menu -->
                <ul class="dropdown-menu">
                  <li> <a href="/produtos/meus-produtos" class="dropdown-item">
                    <i class="fa-solid fa-shop"></i>
                    Meu painel </a> 
                  </li>
                </ul>
            </div>
            <!-- Opção de vitrine -->
            <a href="/produtos/vitrine" class="btn" style="border:none; background:transparent; padding:10px">
              <i class="fa-solid fa-shop"></i> Vitrine Pública
            </a>
          <% } %>

          <!-- Se for interessado -->
          <% if (usuario.perfil === 'interessado' ) { %>
            <!-- Opção de vitrine -->
            <a href="/produtos/vitrine" class="btn" style="border:none; background:transparent; padding:10px">
              <i class="fa-solid fa-shop"></i> Vitrine Pública
            </a>
          <% } %>

          <!-- BOTÃO DE SAIR -->
          <a href="/usuarios/logout" class="btn btn-danger" style="margin-left: 20px">
              <i class="fa-solid fa-right-from-bracket"></i> Sair
          </a>

        <!-- SE NÃO TIVER LOGADO -->
        <%} else { %>
          <!-- botao pra fazer login -->
          <a href="/login" class="btn btn-primary" 
          style="background-color: var(--cor-destaque); border: 2px solid var(--cor-fundo);">
            <i class="fa-solid fa-right-from-bracket"></i> Fazer login
          </a>

          <!-- botao pra fazer cadarastro -->
          <a href="/cadastro" class="btn btn-secondary">
              <i class="fa-solid fa-user-plus"></i> Criar conta
          </a>

        <% } %>

      </nav>
    </header>
  </body>
</html>
